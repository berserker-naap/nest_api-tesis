# Copy this file to .env for local development only.
# In production, configure the same variable names in Azure App Settings.
APP_ENV=development
NODE_ENV=development
API_PREFIX=api
PORT=3000
HOST_API=http://localhost:3000/api

# Local database
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true
DB_REQUEST_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=30000

# Authentication and CORS
JWT_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost
CORS_ALLOW_NO_ORIGIN=true
APP_TRUST_PROXY=false
DECOLECTA_API_KEY=

# Local ML service. Set the HTTPS Azure URL in production App Settings.
ML_SERVICE_URL=http://127.0.0.1:8001
ML_SERVICE_TIMEOUT_MS=8000

# Assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=420
GEMINI_TIMEOUT_MS=20000
GEMINI_INPUT_COST_PER_1M_USD=0
GEMINI_OUTPUT_COST_PER_1M_USD=0
ASSISTANT_HISTORY_LIMIT=20
ASSISTANT_HISTORY_MESSAGE_MAX_CHARS=4000
ASSISTANT_MESSAGES_DEFAULT_LIMIT=50
ASSISTANT_RECENT_TX_LIMIT=20
ASSISTANT_MAX_CONTEXT_CHARS=12000
ASSISTANT_TOOL_PAYLOAD_MAX_CHARS=6000
ASSISTANT_MAX_RESPONSE_CHARS=2200
ASSISTANT_MONTHLY_BUDGET_USD=0

# Analytics
ANALYTICS_LOOKBACK_DAYS=365
ANALYTICS_MAX_TRANSACTIONS=1200

# Exchange rates
EXCHANGERATES_API_KEY=
EXCHANGERATES_API_URL=https://api.exchangeratesapi.io/v1/latest

# Azure integrations
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_PROFILE=
AZURE_STORAGE_SAS_EXPIRES_MINUTES=60
PROFILE_PHOTO_MAX_SIZE_MB=5
PROFILE_PHOTO_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_EMAIL_SENDER_ADDRESS=
AZURE_EMAIL_DEFAULT_REPLY_TO=
AZURE_EMAIL_TEST_MODE=true
AZURE_EMAIL_TEST_RECIPIENT=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PUSH_TEST_MODE=true
FIREBASE_PUSH_TEST_TAG=

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v22.0
